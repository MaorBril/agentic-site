{
  "name": "agentic-site-remotion",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion project that renders the agentic hero demo video.",
  "scripts": {
    "studio": "remotion studio",
    "render:mp4": "remotion render Hero out/hero.mp4 --codec=h264 --crf=18",
    "render:webm": "remotion render Hero out/hero.webm --codec=vp9 --crf=18",
    "still": "remotion still Hero out/poster.png --frame=560",
    "build": "npm run render:webm && npm run render:mp4 && npm run still"
  },
  "dependencies": {
    "@remotion/cli": "4.0.286",
    "@remotion/transitions": "4.0.286",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.286"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "typescript": "5.5.4"
  }
}
